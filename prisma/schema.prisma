generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  phone_number       String    @unique
  stripe_customer_id String?   @unique
  status             String    @default("TRIAL")
  created_at         DateTime  @default(now())

  messages           Message[]
  expenses           Expense[]
  incomes            Income[]
  tasks              Task[]
  notes              Note[]

  @@map("fin_users")
}

model Message {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  role       String   // "user" ou "assistant"
  content    String
  created_at DateTime @default(now())

  @@map("fin_messages")
}

model Expense {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  amount      Float
  description String
  category    String   @default("Outros")
  date        DateTime @default(now())

  @@map("fin_expenses")
}

model Income {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  amount      Float
  description String
  category    String   @default("Renda")
  date        DateTime @default(now())

  @@map("fin_incomes")
}

model Task {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  title       String
  due_date    DateTime?
  completed   Boolean  @default(false)
  notified    Boolean  @default(false)
  notified_5min Boolean @default(false)
  reminder_active Boolean @default(true)
  created_at  DateTime @default(now())

  @@map("fin_tasks")
}

model Note {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  content     String
  created_at  DateTime @default(now())

  @@map("fin_notes")
}
